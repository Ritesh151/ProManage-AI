# Python AI Service Configuration

# Server
PYTHON_AI_HOST=0.0.0.0
PYTHON_AI_PORT=8000
PYTHON_AI_URL=http://localhost:8000

# Node Backend
NODE_BACKEND_URL=http://localhost:5000

# LLM Provider
AI_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Gemini Configuration (optional)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-pro

# Ollama Configuration (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Embedding Configuration
AI_EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=project_knowledge

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-knowledge

# Chunking Configuration
AI_CHUNK_SIZE=1000
AI_CHUNK_OVERLAP=200

# Retrieval Configuration
AI_TOP_K=5
AI_SIMILARITY_THRESHOLD=0.5

# Training Configuration
AI_BATCH_SIZE=10
AI_MAX_CONCURRENT_FILES=5
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY=1000

# Watcher Configuration
AI_WATCHER_ENABLED=true
AI_WATCHER_DEBOUNCE=2000

# Logging Configuration
AI_LOG_LEVEL=info
AI_LOG_FILE=./logs/ai.log

# Cache Configuration
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600

# Environment
ENVIRONMENT=development
DEBUG=true
